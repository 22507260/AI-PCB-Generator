# OpenAI-compatible API key (required)
OPENAI_API_KEY=sk-your-key-here

# Custom API base URL (optional, for OpenAI-compatible providers)
# Examples:
#   Ollama:      http://localhost:11434/v1
#   Groq:        https://api.groq.com/openai/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Together AI: https://api.together.xyz/v1
#   LM Studio:   http://localhost:1234/v1
#   DeepSeek:    https://api.deepseek.com/v1
# OPENAI_BASE_URL=

# Model name (optional, default: gpt-4o)
OPENAI_MODEL=gpt-4o

# KiCad installation path (optional, auto-detected)
# KICAD_PATH=C:\Program Files\KiCad\8.0

# Freerouting JAR path (optional)
# FREEROUTING_JAR=C:\tools\freerouting.jar

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
